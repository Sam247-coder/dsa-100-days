#include <stdio.h>
#define MAX 100

int pq[MAX];
int size = 0;

// Insert element
void enqueue(int value) {
    if(size == MAX) {
        printf("Priority Queue Overflow\n");
        return;
    }

    pq[size] = value;
    size++;
}

// Delete element with highest priority (smallest value)
int dequeue() {
    if(size == 0) {
        printf("Priority Queue Underflow\n");
        return -1;
    }

    int minIndex = 0;

    for(int i = 1; i < size; i++) {
        if(pq[i] < pq[minIndex]) {
            minIndex = i;
        }
    }

    int item = pq[minIndex];

    for(int i = minIndex; i < size - 1; i++) {
        pq[i] = pq[i + 1];
    }

    size--;

    return item;
}

// Display queue
void display() {
    if(size == 0) {
        printf("Queue is empty\n");
        return;
    }

    printf("Priority Queue: ");
    for(int i = 0; i < size; i++) {
        printf("%d ", pq[i]);
    }
    printf("\n");
}

int main() {

    enqueue(30);
    enqueue(10);
    enqueue(50);
    enqueue(20);

    display();

    printf("Removed element: %d\n", dequeue());

    display();

    return 0;
}
