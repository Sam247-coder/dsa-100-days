#include <stdio.h>
#include <stdlib.h>

void dfs(int node, int n, int** graph, int* graphColSize, int* visited) {
    visited[node] = 1;

    for (int i = 0; i < graphColSize[node]; i++) {
        int neighbor = graph[node][i];
        if (!visited[neighbor]) {
            dfs(neighbor, n, graph, graphColSize, visited);
        }
    }
}

int countComponents(int n, int** graph, int* graphColSize) {
    int* visited = (int*)calloc(n, sizeof(int));
    int count = 0;

    for (int i = 0; i < n; i++) {
        if (!visited[i]) {
            dfs(i, n, graph, graphColSize, visited);
            count++;
        }
    }

    free(visited);
    return count;
}
