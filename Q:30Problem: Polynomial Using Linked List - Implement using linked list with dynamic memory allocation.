#include <stdio.h>
#include <stdlib.h>

struct Node {
    int coeff;
    int pow;
    struct Node* next;
};

struct Node* createNode(int c, int p) {
    struct Node* newNode = (struct Node*)malloc(sizeof(struct Node));
    newNode->coeff = c;
    newNode->pow = p;
    newNode->next = NULL;
    return newNode;
}

void insertTerm(struct Node** head, int c, int p) {
    struct Node* newNode = createNode(c, p);

    if (*head == NULL || (*head)->pow < p) {
        newNode->next = *head;
        *head = newNode;
        return;
    }

    struct Node* temp = *head;
    while (temp->next != NULL && temp->next->pow > p)
        temp = temp->next;

    if (temp->next != NULL && temp->next->pow == p) {
        temp->next->coeff += c;
    } else {
        newNode->next = temp->next;
        temp->next = newNode;
    }
}

void display(struct Node* head) {
    while (head != NULL) {
        printf("%dx^%d", head->coeff, head->pow);
        head = head->next;
        if (head != NULL)
            printf(" + ");
    }
    printf("\n");
}

int main() {
    struct Node* poly = NULL;
    int n, c, p;

    printf("Enter number of terms: ");
    scanf("%d", &n);

    for (int i = 0; i < n; i++) {
        printf("Enter coefficient and power: ");
        scanf("%d %d", &c, &p);
        insertTerm(&poly, c, p);
    }

    printf("Polynomial: ");
    display(poly);

    return 0;
}
