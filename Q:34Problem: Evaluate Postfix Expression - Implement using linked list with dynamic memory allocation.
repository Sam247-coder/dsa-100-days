#include <stdio.h>
#include <stdlib.h>
#include <ctype.h>

struct Node{
    int data;
    struct Node* next;
};

struct Node* top = NULL;

void push(int x){
    struct Node* newnode = (struct Node*)malloc(sizeof(struct Node));
    newnode->data = x;
    newnode->next = top;
    top = newnode;
}

int pop(){
    if(top == NULL)
        return -1;
    struct Node* temp = top;
    int x = temp->data;
    top = top->next;
    free(temp);
    return x;
}

int evaluatePostfix(char exp[]){
    int i = 0;
    while(exp[i] != '\0'){
        if(isdigit(exp[i])){
            push(exp[i] - '0');
        }
        else{
            int val1 = pop();
            int val2 = pop();

            switch(exp[i]){
                case '+': push(val2 + val1); break;
                case '-': push(val2 - val1); break;
                case '*': push(val2 * val1); break;
                case '/': push(val2 / val1); break;
            }
        }
        i++;
    }
    return pop();
}

int main(){
    char exp[100];
    printf("Enter postfix expression: ");
    scanf("%s", exp);

    int result = evaluatePostfix(exp);
    printf("Result = %d", result);

    return 0;
}
