#include <stdio.h>
#include <stdlib.h>

#define MAX 100

typedef struct {
    int arr[MAX];
    int front, rear;
} Queue;

typedef struct {
    int arr[MAX];
    int top;
} Stack;

void enqueue(Queue *q, int x) {
    q->arr[++q->rear] = x;
}

int dequeue(Queue *q) {
    return q->arr[q->front++];
}

int isQueueEmpty(Queue *q) {
    return q->front > q->rear;
}

void push(Stack *s, int x) {
    s->arr[++s->top] = x;
}

int pop(Stack *s) {
    return s->arr[s->top--];
}

int isStackEmpty(Stack *s) {
    return s->top == -1;
}

void reverseQueue(Queue *q) {
    Stack s;
    s.top = -1;

    while (!isQueueEmpty(q)) {
        push(&s, dequeue(q));
    }

    while (!isStackEmpty(&s)) {
        enqueue(q, pop(&s));
    }
}

int main() {
    Queue q;
    q.front = 0;
    q.rear = -1;

    enqueue(&q, 10);
    enqueue(&q, 20);
    enqueue(&q, 30);
    enqueue(&q, 40);

    reverseQueue(&q);

    while (!isQueueEmpty(&q)) {
        printf("%d ", dequeue(&q));
    }

    return 0;
}
