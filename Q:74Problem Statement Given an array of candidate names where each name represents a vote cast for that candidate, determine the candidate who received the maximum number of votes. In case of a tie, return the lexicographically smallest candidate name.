#include <bits/stdc++.h>
using namespace std;

string winner(string arr[], int n) {
    unordered_map<string, int> freq;

    // Count votes
    for (int i = 0; i < n; i++) {
        freq[arr[i]]++;
    }

    string ans = "";
    int maxVotes = 0;

    // Find winner
    for (auto it : freq) {
        string name = it.first;
        int votes = it.second;

        if (votes > maxVotes) {
            maxVotes = votes;
            ans = name;
        } 
        else if (votes == maxVotes) {
            if (name < ans) { // lexicographically smaller
                ans = name;
            }
        }
    }

    return ans;
}

int main() {
    string arr[] = {"john", "johnny", "jackie", "johnny", "john", "jackie", "jamie", "jamie", "john", "johnny", "jamie", "johnny", "john"};
    int n = sizeof(arr) / sizeof(arr[0]);

    cout << winner(arr, n);
}
