class Solution {
public:
    char nonRepeatingChar(string s) {
        vector<int> freq(26, 0);

        // Step 1: Count frequencies
        for (char ch : s) {
            freq[ch - 'a']++;
        }

        // Step 2: Find first non-repeating
        for (char ch : s) {
            if (freq[ch - 'a'] == 1) {
                return ch;
            }
        }

        return '$'; // if all repeat
    }
};
