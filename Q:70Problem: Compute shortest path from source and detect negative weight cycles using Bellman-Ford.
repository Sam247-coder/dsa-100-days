#include <stdio.h>
#include <limits.h>

void bellmanFord(int n, int edges[][3], int e, int src) {
    
    int dist[n];

    // Step 1: Initialize
    for(int i = 0; i < n; i++) {
        dist[i] = INT_MAX;
    }
    dist[src] = 0;

    // Step 2: Relax edges n-1 times
    for(int i = 0; i < n - 1; i++) {
        for(int j = 0; j < e; j++) {
            int u = edges[j][0];
            int v = edges[j][1];
            int w = edges[j][2];

            if(dist[u] != INT_MAX && dist[u] + w < dist[v]) {
                dist[v] = dist[u] + w;
            }
        }
    }

    // Step 3: Detect negative cycle
    int hasNegativeCycle = 0;
    for(int j = 0; j < e; j++) {
        int u = edges[j][0];
        int v = edges[j][1];
        int w = edges[j][2];

        if(dist[u] != INT_MAX && dist[u] + w < dist[v]) {
            hasNegativeCycle = 1;
            break;
        }
    }

    // Step 4: Output
    if(hasNegativeCycle) {
        printf("Negative weight cycle detected\n");
    } else {
        printf("Shortest distances from source %d:\n", src);
        for(int i = 0; i < n; i++) {
            if(dist[i] == INT_MAX)
                printf("Node %d: INF\n", i);
            else
                printf("Node %d: %d\n", i, dist[i]);
        }
    }
}
